# ============================================================
# .gitignore - HJS Dashboard
# ============================================================

# 절대 올리면 안 되는 파일
.env
.env.local
.env.production
.env.*.local

# Node 모듈
node_modules/
npm-debug.log*

# 로그 파일
logs/
*.log

# DB 덤프 (민감한 데이터 포함 가능)
*.sql.bak
dump_*.sql
backup_*.sql

# OS 생성 파일
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp

# 빌드 결과물
dist/
build/

# ============================================================
# GitHub에 올려도 되는 파일
# ============================================================
# .env.example     → 올려도 됨 (값 없음)
# schema.sql       → 올려도 됨 (DDL만, 데이터 없음)
# package.json     → 올려도 됨
# README.md        → 올려도 됨
# 소스코드 전체    → 올려도 됨 (.env 분리된 경우)
