# ============================================================
#  HJS Backend — 환경변수 예시 (.env)
#  ⚠ 실제 .env 파일은 절대 GitHub에 올리지 마세요!
#  이 파일(.env.example)만 커밋하세요.
# ============================================================

# ─── 서버 설정 ───────────────────────────────────────────
PORT=3000
NODE_ENV=development          # development | production

# ─── MySQL 접속 정보 ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=hjs_user
DB_PASSWORD=your_strong_password_here
DB_NAME=hjs_db

# ─── JWT 설정 ────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── 텔레그램 알림 설정 ───────────────────────────────────
# BotFather에서 /newbot 으로 생성
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
# @userinfobot 에서 내 chat_id 확인
TELEGRAM_CHAT_ID=123456789

# ─── CORS 허용 Origin ─────────────────────────────────────
FRONTEND_URL=http://localhost:5500

# ─── IP 위치 API (선택) ───────────────────────────────────
# https://ipapi.co 무료 플랜 사용 (1,000회/일)
IPAPI_KEY=
