# ================================================================
# HJS Dashboard — .env.example
# 이 파일은 GitHub에 올려도 됩니다 (실제 값이 없으므로)
#
# 사용법:
#   cp .env.example .env
#   .env 파일 열어서 각 값 입력 → GitHub에는 절대 올리지 않기
# ================================================================

# ── 서버 기본 설정 ───────────────────────────────────────────
PORT=3000
# 로컬 개발 시: development  /  실제 서버 배포 시: production
NODE_ENV=development

# ── MySQL / MariaDB 접속 정보 ────────────────────────────────
# 로컬 개발 시: localhost
# 원격 서버 배포 시: 서버 IP 또는 도메인 (예: 123.456.78.90)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hjs_db
DB_USER=hjs_user
DB_PASS=여기에_강한_비밀번호_입력

# ── JWT 인증 설정 ─────────────────────────────────────────────
# 최소 32자 이상 랜덤 문자열 (예: openssl rand -base64 32 로 생성)
JWT_SECRET=여기에_32자_이상_랜덤문자열_입력
JWT_EXPIRES_IN=7d

# ── 텔레그램 봇 설정 ─────────────────────────────────────────
# BotFather 에서 발급받은 토큰
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
# 본인의 Chat ID (@userinfobot 에서 확인)
TELEGRAM_CHAT_ID=123456789

# ── 프론트엔드 URL (운영 시 CORS 허용 주소) ───────────────────
# 로컬 개발 시: http://localhost:3000
# 실제 배포 후: https://내도메인.com 또는 http://서버IP:3000
FRONTEND_URL=http://localhost:3000

# ── 관리자 초기 계정 ─────────────────────────────────────────
# node scripts/initAdmin.js 실행 시 1회만 사용
# 실행 후 이 두 줄은 .env에서 삭제 권장
ADMIN_USERNAME=admin
ADMIN_PASSWORD=여기에_관리자_비밀번호_입력
